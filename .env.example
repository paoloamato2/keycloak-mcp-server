# Keycloak MCP Server - Environment Variables
# Copy to .env and fill in your values

# Keycloak host (include http:// or https:// prefix)
KEYCLOAK_URL=http://localhost:8080

# Admin realm
KEYCLOAK_ADMIN_REALM=master

# Client ID
KEYCLOAK_CLIENT_ID=admin-cli

# Option 1: Client Credentials Grant (Service Account)
KEYCLOAK_CLIENT_SECRET=

# Option 2: Password Grant (Username & Password)
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Whether to verify the SSL certificate (set to false for self-signed certs)
KEYCLOAK_VERIFY_SSL=true
